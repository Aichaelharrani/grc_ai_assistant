<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_grc_anomaly_list" model="ir.ui.view">
        <field name="name">grc.anomaly.list</field>
        <field name="model">grc.anomaly</field>
        <field name="arch" type="xml">
            <list string="Anomalies GRC" decoration-danger="risk_level == 'critical'"
                  decoration-warning="risk_level == 'high'">
                <field name="name"/>
                <field name="anomaly_type"/>
                <field name="user_id"/>
                <field name="risk_score"/>
                <field name="risk_level"/>
                <field name="iso27001_control_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_grc_anomaly_form" model="ir.ui.view">
        <field name="name">grc.anomaly.form</field>
        <field name="model">grc.anomaly</field>
        <field name="arch" type="xml">
            <form string="Anomalie GRC">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,investigating,resolved,false_positive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="anomaly_type"/>
                            <field name="log_entry_id"/>
                            <field name="user_id"/>
                            <field name="detection_date"/>
                        </group>
                        <group>
                            <field name="risk_score"/>
                            <field name="risk_level"/>
                            <field name="iso27001_control_id"/>
                        </group>
                    </group>
                    <field name="recommendation" placeholder="Recommandation générée par l'IA..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_grc_anomaly_search" model="ir.ui.view">
        <field name="name">grc.anomaly.search</field>
        <field name="model">grc.anomaly</field>
        <field name="arch" type="xml">
            <search string="Rechercher une anomalie">
                <field name="name"/>
                <field name="user_id"/>
                <field name="anomaly_type"/>
                <filter string="Critiques" name="filter_critical" domain="[('risk_level', '=', 'critical')]"/>
                <filter string="Nouvelles" name="filter_new" domain="[('state', '=', 'new')]"/>
                <group expand="0" string="Regrouper par">
                    <filter string="Type" name="group_type" context="{'group_by': 'anomaly_type'}"/>
                    <filter string="Niveau de risque" name="group_level" context="{'group_by': 'risk_level'}"/>
                    <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_grc_anomaly" model="ir.actions.act_window">
        <field name="name">Anomalies</field>
        <field name="res_model">grc.anomaly</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
