<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_ingest_logs" model="ir.cron">
            <field name="name">GRC: Ingestion des journaux (ir.logging)</field>
            <field name="model_id" ref="model_grc_log_entry"/>
            <field name="state">code</field>
            <field name="code">model._cron_ingest_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_rgpd_purge" model="ir.cron">
            <field name="name">GRC: Purge RGPD / anonymisation des IP</field>
            <field name="model_id" ref="model_grc_log_entry"/>
            <field name="state">code</field>
            <field name="code">model._cron_rgpd_purge()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
